# Security
EDIT_KEY=demo-finance-key

# Android/Capacitor: URL absoluta do backend hospedado na Vercel no build nativo.
NUXT_PUBLIC_API_BASE_URL=
NUXT_PUBLIC_APP_VERSION=1.1.0
# Identificador do build web usado para detectar atualizações em páginas abertas.
# Em Vercel/GitHub Actions ele é obtido automaticamente; deixe vazio localmente.
NUXT_PUBLIC_WEB_BUILD_VERSION=
# URL pública da API que informa a última versão Android publicada.
NUXT_PUBLIC_UPDATE_MANIFEST_URL=
# Origens autorizadas a chamar a API hospedada a partir do app Android.
MOBILE_ALLOWED_ORIGINS=https://localhost

# Optional Supabase (server persistence). If empty, app uses in-memory repository + dados.txt seed.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_SECRET_KEY=

# Public/browser Supabase key (publishable/anon)
NUXT_PUBLIC_SUPABASE_URL=
NUXT_PUBLIC_SUPABASE_ANON_KEY=

# Compatibility with Next/Supabase docs naming
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional custom path for seed source
DATA_FILE_PATH=

# Usado somente pelo CLI do Capgo para publicar atualizações OTA. Nunca versionar.
CAPGO_TOKEN=
